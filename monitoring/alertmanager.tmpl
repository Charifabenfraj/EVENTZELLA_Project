{{ define "email.html" }}
<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
  </head>
  <body style="margin:0;padding:0;background:#f6f7fb;color:#222;font-family:Arial,Helvetica,sans-serif;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#f6f7fb;padding:24px 0;">
      <tr>
        <td align="center">
          <table role="presentation" width="680" cellspacing="0" cellpadding="0" style="background:#ffffff;border:1px solid #e5e7eb;border-radius:8px;overflow:hidden;">
            <tr>
              <td style="padding:16px 20px;background:#111827;color:#ffffff;">
                <div style="font-size:18px;font-weight:700;">Eventzella Monitoring Alert</div>
                <div style="font-size:12px;opacity:0.85;">Status: {{ .Status }}</div>
              </td>
            </tr>
            <tr>
              <td style="padding:16px 20px;">
                <div style="font-size:16px;font-weight:700;">{{ .CommonLabels.alertname }}</div>
                <div style="font-size:12px;color:#6b7280;margin-top:4px;">
                  {{ if .CommonAnnotations.summary }}{{ .CommonAnnotations.summary }}{{ else }}Alert triggered{{ end }}
                </div>
              </td>
            </tr>
            <tr>
              <td style="padding:0 20px 16px;">
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="border-collapse:collapse;font-size:13px;">
                  <tr style="background:#f3f4f6;">
                    <th align="left" style="padding:8px;border-bottom:1px solid #e5e7eb;">Alert</th>
                    <th align="left" style="padding:8px;border-bottom:1px solid #e5e7eb;">Instance</th>
                    <th align="left" style="padding:8px;border-bottom:1px solid #e5e7eb;">Severity</th>
                    <th align="left" style="padding:8px;border-bottom:1px solid #e5e7eb;">Starts</th>
                  </tr>
                  {{ range .Alerts }}
                  {{ $sev := .Labels.severity }}
                  <tr>
                    <td style="padding:8px;border-bottom:1px solid #e5e7eb;">{{ .Labels.alertname }}</td>
                    <td style="padding:8px;border-bottom:1px solid #e5e7eb;">{{ .Labels.instance }}</td>
                    <td style="padding:8px;border-bottom:1px solid #e5e7eb;">
                      <span style="display:inline-block;padding:2px 8px;border-radius:999px;font-size:12px;color:#fff;{{ if eq $sev "critical" }}background:#dc2626;{{ else if eq $sev "warning" }}background:#f59e0b;{{ else }}background:#2563eb;{{ end }}">
                        {{ $sev }}
                      </span>
                    </td>
                    <td style="padding:8px;border-bottom:1px solid #e5e7eb;">{{ .StartsAt }}</td>
                  </tr>
                  {{ end }}
                </table>
              </td>
            </tr>
            <tr>
              <td style="padding:12px 20px;border-top:1px solid #e5e7eb;font-size:12px;color:#6b7280;">
                <div style="font-weight:700;margin-bottom:6px;color:#111827;">Details</div>
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="border-collapse:collapse;font-size:12px;">
                  {{ range .CommonLabels.SortedPairs }}
                  <tr>
                    <td style="padding:4px 6px;border-bottom:1px solid #e5e7eb;width:160px;color:#374151;">{{ .Name }}</td>
                    <td style="padding:4px 6px;border-bottom:1px solid #e5e7eb;color:#111827;">{{ .Value }}</td>
                  </tr>
                  {{ end }}
                </table>
                {{ if .CommonAnnotations.description }}
                <div style="margin-top:10px;color:#374151;">{{ .CommonAnnotations.description }}</div>
                {{ end }}
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
{{ end }}

{{ define "email.text" }}
[Eventzella] {{ .CommonLabels.alertname }} ({{ .Status }})
{{ if .CommonAnnotations.summary }}{{ .CommonAnnotations.summary }}{{ else }}Alert triggered{{ end }}

Alerts:
{{ range .Alerts }}- {{ .Labels.alertname }} on {{ .Labels.instance }} ({{ .Labels.severity }})
{{ end }}

Details:
{{ range .CommonLabels.SortedPairs }}- {{ .Name }}: {{ .Value }}
{{ end }}
{{ if .CommonAnnotations.description }}

Description:
{{ .CommonAnnotations.description }}
{{ end }}
{{ end }}
