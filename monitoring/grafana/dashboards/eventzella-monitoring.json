{
  "title": "Eventzella Monitoring",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Traffic (req/s)",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(rate(http_requests_total[1m]))", "legendFormat": "requests" }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error rate (%)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "100 * sum(rate(http_requests_total{status=~\"5..\"}[1m])) / sum(rate(http_requests_total[1m]))",
          "legendFormat": "error %"
        }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Latency p95 (s)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Model accuracy vs baseline",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "model_accuracy_current", "legendFormat": "current {{model_key}}" },
        { "expr": "model_accuracy_baseline", "legendFormat": "baseline {{model_key}}" }
      ],
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Model confidence",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "model_prediction_confidence", "legendFormat": "confidence {{model_key}}" }
      ],
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Data health (missing & drift)",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "model_missing_rate", "legendFormat": "missing {{model_key}}" },
        { "expr": "model_drift_score", "legendFormat": "drift {{model_key}}" }
      ],
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 }
    }
  ]
}
